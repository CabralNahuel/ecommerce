<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs', { titulo }) %>
  <body>
    <%- include('partials/header') -%>
    <main class="contact-page container">
      <section class="contact-card" aria-labelledby="contact-heading">
        <form id="form" class="contact-form" action="/contact" method="POST" novalidate>
          <h2 id="contact-heading" class="contact-card__title">Contacto</h2>
          <p class="contact-card__subtitle">
            Escribinos y te respondemos a la brevedad.
          </p>

          <div class="login-field">
            <label class="login-field__label" for="nombre">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              class="login-input"
              placeholder="Tu nombre"
              autocomplete="given-name"
              required
            />
            <span id="nombre_error" class="login-field__error" role="alert"></span>
          </div>

          <div class="login-field">
            <label class="login-field__label" for="apellido">Apellido</label>
            <input
              type="text"
              id="apellido"
              name="apellido"
              class="login-input"
              placeholder="Tu apellido"
              autocomplete="family-name"
              required
            />
            <span id="apellido_error" class="login-field__error" role="alert"></span>
          </div>

          <div class="login-field">
            <label class="login-field__label" for="correo">Correo</label>
            <input
              type="email"
              id="correo"
              name="correo"
              class="login-input"
              placeholder="usuario@dominio.com"
              autocomplete="email"
              required
            />
            <span id="correo_error" class="login-field__error" role="alert"></span>
          </div>

          <div class="login-field">
            <label class="login-field__label" for="asunto">Asunto</label>
            <input
              type="text"
              id="asunto"
              name="asunto"
              class="login-input"
              placeholder="Motivo de la consulta"
              autocomplete="off"
              required
            />
            <span id="asunto_error" class="login-field__error" role="alert"></span>
          </div>

          <div class="login-field">
            <label class="login-field__label" for="mensaje">Mensaje</label>
            <textarea
              id="mensaje"
              name="mensaje"
              class="login-input contact-form__textarea"
              rows="5"
              placeholder="Contanos en qué podemos ayudarte"
              autocomplete="off"
              required
            ></textarea>
            <span id="mensaje_error" class="login-field__error" role="alert"></span>
          </div>

          <div class="contact-form__actions">
            <input
              type="submit"
              class="login-submit"
              id="enviar"
              value="Enviar"
            />
            <input type="reset" class="shop-filters__reset contact-form__reset" value="Borrar" />
          </div>
        </form>
      </section>
    </main>

    <%- include('partials/footer') -%>
    <%- include('partials/scripts') %>
    <script src="/js/validar.js"></script>
  </body>
</html>
