<li class="producto-lista-item">
  <article class="producto-articulo">
    <p class="producto-id" data-label="ID"><%= card.product_id %></p>
    <p class="producto-sku" data-label="Código"><%= card.product_sku %></p>
    <div class="producto-thumb-wrap" data-label="Imagen">
      <img
        class="producto-thumb"
        src="<%= card.img_front %>"
        alt="Imagen de <%= card.product_name %>"
        loading="lazy"
      />
    </div>
    <h4 class="producto-name" data-label="Producto"><%= card.product_name %></h4>
    <p class="producto-collection" data-label="Categoría">
      <%= card.collection ? card.collection.collection_name : '' %>
    </p>

    <div class="links producto-actions" data-label="Acciones">
      <a href="/admin/edit/<%= card.product_id %>" class="links editar">
        <iconify-icon
          icon="ic:baseline-edit"
          style="color: #1d84b5"
          width="24.37"
          height="25.09"
        ></iconify-icon>
      </a>
      <a
        class="links eliminar"
        onclick="eliminarProducto('<%= card.product_id %>')"
      >
        <iconify-icon
          icon="material-symbols:delete-rounded"
          style="color: #f33"
          width="34"
          height="34"
        ></iconify-icon>
      </a>
    </div>
  </article>
</li>
