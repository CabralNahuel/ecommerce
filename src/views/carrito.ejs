<!DOCTYPE html>
<html lang="es">
  <%- include('partials/head.ejs', { titulo }) %>
  <body>
    <%- include('partials/header') -%>
    <main class="cart-page container">
      <h1 class="cart-page__title">Carrito de compras</h1>

      <div class="cart-page__panel">
        <% if (Array.isArray(carrito) && carrito.length) { %>
          <div class="carrito-tabla" role="table" aria-label="Productos en el carrito">
            <div class="carrito-tabla-h" role="row">
              <div class="carrito-tabla-h-text" role="columnheader">Detalle</div>
              <div class="carrito-tabla-h-text" role="columnheader">Cantidad</div>
              <div class="carrito-tabla-h-text" role="columnheader">Total</div>
              <div class="carrito-tabla-h-text carrito-tabla-h-text--action" role="columnheader">Quitar</div>
            </div>

            <% carrito.forEach(function (item) { %>
              <%- include('partials/cart_tablerow', { item }) %>
            <% }) %>
          </div>
        <% } else { %>
          <p class="cart-page__empty">Tu carrito está vacío. <a href="/shop">Ver productos</a></p>
        <% } %>
      </div>

      <% if (Array.isArray(carrito) && carrito.length) { %>
        <section class="cart-page__summary total" aria-labelledby="resumen-heading">
          <article class="total-grid">
            <h2 id="resumen-heading" class="cart-page__summary-title">Resumen</h2>
            <div class="total-card">
              <div class="total-grupo-card">
                <div class="total-descri-card">
                  <span>Cantidad de ítems</span>
                  <span>Subtotal</span>
                  <span>Envío</span>
                </div>
                <div class="total-precio-card">
                  <span id="canti">0</span>
                  <span id="subtot">0.00</span>
                  <span>0.00</span>
                </div>
              </div>
              <div class="total-grupo-card total-grupo-card-cont">
                <span>Total</span>
                <span id="total">0.00</span>
              </div>
              <input type="button" id="pagar" class="total-item-boton" value="Ir a pagar" />
            </div>
          </article>
        </section>
      <% } %>
    </main>

    <%- include('partials/footer') -%>
    <%- include('partials/scripts') %>
    <script src="/js/carrito.js"></script>
  </body>
</html>
