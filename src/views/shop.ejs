<!DOCTYPE html>
<html lang="en">
  <%-include('partials/head.ejs', {titulo}) %>
  <body>
    <%- include('partials/header') -%>

    <main class="container_shop shop-page">
      <%- include('partials/shop_filters') %>

      <section class="shop-page__results">
        <% if (typeof pagination !== 'undefined') { %>
        <p class="shop-page__meta" aria-live="polite">
          <%= pagination.total %> producto<% if (pagination.total !== 1) { %>s<% } %>
          <% if (pagination.totalPages > 1) { %>
            · página <%= pagination.page %> de <%= pagination.totalPages %>
          <% } %>
        </p>
        <% } %>
        <% if (cards && cards.length) { %>
        <ul class="items shop-items">
          <% cards.forEach(function(card) { %>
            <%- include('partials/shop_items', { card }) %>
          <% }); %>
        </ul>
        <% } else { %>
        <p class="shop-page__empty">No hay productos con los filtros elegidos.</p>
        <% } %>

        <%- include('partials/shop_pagination') %>
      </section>
    </main>

    <%- include('partials/footer') -%>
    <script src="https://cdn.jsdelivr.net/npm/iconify-icon@1.0.7/dist/iconify-icon.min.js"></script>
  </body>
</html>
